rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write for users to manage their profiles (either Firebase Auth users or simulated guest users)
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Allow read/write for searchHistory to track pricing queries
    match /searchHistory/{historyId} {
      allow read, write: if true;
    }

    // Allow read/write for appointments
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }
  }
}
